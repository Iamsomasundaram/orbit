ORBIT_ENV=local
WEB_PORT=5000
API_PORT=5001
POSTGRES_PORT=5002
REDIS_PORT=5003
WORKER_PORT=5004

WEB_INTERNAL_PORT=3000
API_INTERNAL_PORT=8001
WORKER_INTERNAL_PORT=8002

POSTGRES_DB=orbit
POSTGRES_USER=orbit
POSTGRES_PASSWORD=orbit
POSTGRES_HOST=postgres
POSTGRES_INTERNAL_PORT=5432
DATABASE_URL=postgresql+psycopg://orbit:orbit@postgres:5432/orbit

REDIS_HOST=redis
REDIS_INTERNAL_PORT=6379
REDIS_URL=redis://redis:6379/0

NEXT_PUBLIC_APP_NAME=ORBIT
NEXT_PUBLIC_PLATFORM_MILESTONE=11
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001
INTERNAL_API_BASE_URL=http://api:8001
PORTFOLIO_STORAGE_DIR=/workspace/.orbit-data/portfolio-submissions

JS_BASELINE_MODE=reference
JS_BASELINE_ARCHIVAL_STAGE=archived-baseline
JS_BASELINE_ARCHIVAL_TARGET_MILESTONE=Milestone 7.1

LLM_RUNTIME_MODE=deterministic
LLM_MAX_CONCURRENCY=6
LLM_REQUEST_TIMEOUT_SECONDS=25
LLM_MAX_OUTPUT_TOKENS=700
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_API_KEY_FILE=/workspace/key.txt
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=
